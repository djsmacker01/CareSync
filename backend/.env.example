PORT=3001
NODE_ENV=production

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=your-jwt-secret
# Allowed frontend origin(s) — comma-separate multiple values for staging + prod
# e.g. FRONTEND_URL=https://app.caresync.com,https://staging.caresync.com
FRONTEND_URL=https://care-sync-delta.vercel.app/

# Sentry error monitoring (optional - leave blank to disable)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=

