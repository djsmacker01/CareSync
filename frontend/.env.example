VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API URL (set to your deployed backend URL in production)
VITE_BACKEND_URL=https://caresync.railway.app

# Sentry error monitoring (optional - leave blank to disable in dev)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=

# App version shown in Sentry releases (set by your CI/CD pipeline)
VITE_APP_VERSION=
